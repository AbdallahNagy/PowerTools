<Project Sdk="Microsoft.NET.Sdk.Web">

    <PropertyGroup>
        <TargetFramework>net9.0</TargetFramework>
        <Nullable>enable</Nullable>
        <ImplicitUsings>enable</ImplicitUsings>
        <RootNamespace>PowerTools.API</RootNamespace>
        <AssemblyName>PowerTools.API</AssemblyName>
        <InvariantGlobalization>true</InvariantGlobalization>
    </PropertyGroup>

    <!-- Self-contained, single-file publish for sidecar distribution.
         Activate with: dotnet publish -c Release -r <rid> -p:PublishingForSidecar=true -->
    <PropertyGroup Condition="'$(PublishingForSidecar)' == 'true'">
        <PublishSingleFile>true</PublishSingleFile>
        <SelfContained>true</SelfContained>
        <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
        <EnableCompressionInSingleFile>true</EnableCompressionInSingleFile>
        <DebugType>embedded</DebugType>
        <!-- Dataverse SDK is not trim-safe. Do not enable PublishTrimmed. -->
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="Microsoft.PowerPlatform.Dataverse.Client" Version="1.2.10" />
    </ItemGroup>

</Project>
